# This is a sample .env file.
# Do not commit the actual .env file to GitHub!

# Backend Port (Render handles this automatically, but great for local dev)
PORT=5000

# Your Frontend URL (Used for CORS restrictions in Production)
FRONTEND_URL=https://your-vercel-site.vercel.app

# Database Connection String (When you add MongoDB/Postgres later)
DATABASE_URI=mongodb+srv://admin:password@cluster.mongodb.net/test
